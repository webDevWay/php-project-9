{
    "name": "hexlet/code",
    "description": "Hexlet Project 3",
    "type": "project",
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\": "tests/"
        }
    },
    "bin": ["public/index.php"],
     "scripts": {
        "lint-fix": "phpcbf --standard=PSR12 src public"
    },
    "authors": [
        {
            "name": "WebDevWay",
            "email": "k.vasiliy.r@gmail.com"
        }
    ],
    "license": "MIT",
    "minimum-stability": "stable",
    "require-dev": {
        "squizlabs/php_codesniffer": "*",
        "friendsofphp/php-cs-fixer": "^3.94"
    },
    "require": {
        "slim/slim": "4.*",
        "slim/psr7": "^1.8",
        "slim/http": "^1.4",
        "slim/php-view": "^3.4",
        "php-di/php-di": "^7.1",
        "slim/flash": "^0.4.0"
    }
}
